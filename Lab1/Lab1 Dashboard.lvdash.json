{
  "datasets": [
    {
      "name": "44f50c4c",
      "displayName": "teams_fouls_2022",
      "config": {
        "version": "1.1",
        "source": "dbr_dev.trezio2005.teams_fouls_2022",
        "dimensions": [
          {
            "name": "team",
            "expr": "source.team",
            "displayName": "Team"
          },
          {
            "name": "total_fouls",
            "expr": "source.total_fouls",
            "displayName": "Total Fouls"
          },
          {
            "name": "total_yellow_cards",
            "expr": "source.total_yellow_cards",
            "displayName": "Total Yellow Cards"
          },
          {
            "name": "total_red_cards",
            "expr": "source.total_red_cards",
            "displayName": "Total Red Cards"
          },
          {
            "name": "region",
            "expr": "source.region",
            "displayName": "Region"
          }
        ]
      }
    },
    {
      "name": "top5_red",
      "displayName": "Top 5 Countries by Red Cards",
      "queryLines": [
        "SELECT team, total_red_cards FROM dbr_dev.trezio2005.teams_fouls_2022\n",
        "WHERE total_red_cards > 0\n",
        "ORDER BY total_red_cards DESC LIMIT 5"
      ]
    },
    {
      "name": "top5_yellow",
      "displayName": "Top 5 Countries by Yellow Cards",
      "queryLines": [
        "SELECT team, total_yellow_cards FROM dbr_dev.trezio2005.teams_fouls_2022\n",
        "ORDER BY total_yellow_cards DESC LIMIT 5"
      ]
    },
    {
      "name": "top5_fouls",
      "displayName": "Top 5 Countries by Fouls",
      "queryLines": [
        "SELECT team, total_fouls FROM dbr_dev.trezio2005.teams_fouls_2022\n",
        "ORDER BY total_fouls DESC LIMIT 5"
      ]
    },
    {
      "name": "fouls_by_region",
      "displayName": "Total Fouls by Region",
      "queryLines": [
        "SELECT region, SUM(total_fouls) AS total_fouls, COUNT(DISTINCT team) AS num_countries\n",
        "FROM dbr_dev.trezio2005.teams_fouls_2022\n",
        "WHERE region IS NOT NULL\n",
        "GROUP BY region\n",
        "ORDER BY total_fouls DESC"
      ]
    },
    {
      "name": "avg_fouls_region",
      "displayName": "Avg Fouls per Team by Region",
      "queryLines": [
        "SELECT region, ROUND(AVG(total_fouls), 1) AS avg_fouls_per_team\n",
        "FROM dbr_dev.trezio2005.teams_fouls_2022\n",
        "WHERE region IS NOT NULL\n",
        "GROUP BY region\n",
        "ORDER BY avg_fouls_per_team DESC"
      ]
    }
  ],
